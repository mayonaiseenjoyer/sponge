local function SwitchTab(index)
    for i, t in ipairs(tabs) do
        t.frame.Visible = (i == index)
        if t.button then
            t.button.TextColor3 = (i == index) and Color3.fromRGB(255, 245, 255) or Color3.fromRGB(180, 140, 220)
        end
    end
    local t = tabs[index]
    if t then
        TweenService:Create(TabIndicator, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, t.x, 1, -2),
            Size = UDim2.new(0, t.w, 0, 2)
        }):Play()
    end
    currentTab = index
end

