local function GetRemotes()
    local RE = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if not RE then return nil, nil, nil end
    return RE:FindFirstChild("GetItem"), RE:FindFirstChild("Drop"), RE:FindFirstChild("Equip")
end

DupeButton.MouseButton1Click:Connect(function()
    local Input = SearchBox.Text
    local Items = {}
    if Input:find(",") then
        for Item in Input:gmatch("[^,]+") do
            local T = Item:gsub("^%s+", ""):gsub("%s+$", "")
            if T ~= "" then table.insert(Items, T) end
        end
    else
        local T = Input:gsub("^%s+", ""):gsub("%s+$", "")
        if T ~= "" then table.insert(Items, T) end
    end
    if #Items == 0 then
        StatusLabel.TextColor3 = Color3.fromRGB(255, 180, 60)
        StatusLabel.Text = " Enter an item name first."
        return
    end
    if #Items > 5 then
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        StatusLabel.Text = " Maximum of 5 items allowed at once."
        return
    end
    local ItemsFolder = ReplicatedStorage:FindFirstChild("Items")
    local Valid = {}
    for _, Name in ipairs(Items) do
        if ItemsFolder and ItemsFolder:FindFirstChild(Name) then table.insert(Valid, Name) end
    end
    if #Valid == 0 then
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        StatusLabel.Text = "No valid items found."
        return
    end
    local GetItem, _, _ = GetRemotes()
    if not GetItem then
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        StatusLabel.Text = "Required remote not found."
        return
    end
    local Overlay = Instance.new("Frame")
    Overlay.Size = UDim2.new(1, 0, 1, 0)
    Overlay.Position = UDim2.new(0, 0, 0, 0)
    Overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Overlay.BackgroundTransparency = 0.75
    Overlay.BorderSizePixel = 0
    Overlay.ZIndex = 100000
    Overlay.Parent = GUI

    local OverlayImage = Instance.new("ImageLabel")
    OverlayImage.Size = UDim2.new(1, 0, 1, 0)
    OverlayImage.Position = UDim2.new(0, 0, 0, 0)
    OverlayImage.BackgroundTransparency = 1
    OverlayImage.Image = "rbxassetid://10251429179"
    OverlayImage.ZIndex = 100001
    OverlayImage.Parent = Overlay

    local OverlayLabel = Instance.new("TextLabel")
    OverlayLabel.Size = UDim2.new(0.8, 0, 0, 80)
    OverlayLabel.Position = UDim2.new(0.5, 0, 0.45, 0)
    OverlayLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    OverlayLabel.BackgroundTransparency = 1
    OverlayLabel.Text = "Duping.. you may rejoin when complete"
    OverlayLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    OverlayLabel.TextScaled = true
    OverlayLabel.Font = Enum.Font.SourceSansBold
    OverlayLabel.ZIndex = 100002
    OverlayLabel.Parent = Overlay

    local Blur = Instance.new("BlurEffect")
    Blur.Size = 24
    Blur.Enabled = true
    Blur.Parent = Lighting

    coroutine.wrap(function()
        local QuestSettings = ReplicatedStorage:FindFirstChild("QuestSettings")
        if not QuestSettings then
            OverlayLabel.Text = "Error: QuestSettings not found."
            return
        end
        local Quests = require(QuestSettings)
        local Success = false
        for _, ItemName in ipairs(Valid) do
            local QuestData = {questName = "Hole", prizeItem = ItemName, questRequiredItems = {"Simple Dimple"}}
            for QuestId, QuestInfo in pairs(Quests) do
                local Required = QuestInfo.questRequiredItems or {}
                for _, Req in ipairs(Required) do
                    if ItemsFolder:FindFirstChild(Req) then
                        GetItem:FireServer(ItemsFolder[Req], QuestData)
                        GetItem:FireServer(ItemsFolder[Req], QuestData)
                    end
                end
                for i = 1, 350 do
                    if ItemsFolder:FindFirstChild(ItemName) then
                        GetItem:FireServer(ItemsFolder[ItemName], QuestData)
                        GetItem:FireServer(ItemsFolder[ItemName], QuestData)
                    end
                end
                local Next = Quests[QuestId + 1]
                if Next then
                    local NextReq = Next.questRequiredItems or {}
                    for _, Req in ipairs(NextReq) do
                        if ItemsFolder:FindFirstChild(Req) then
                            GetItem:FireServer(ItemsFolder[Req], QuestData)
                            GetItem:FireServer(ItemsFolder[Req], QuestData)
                        end
                    end
                end
                for i = 1, 355 do
                    if ItemsFolder:FindFirstChild(ItemName) then
                        GetItem:FireServer(ItemsFolder[ItemName], QuestData)
                        GetItem:FireServer(ItemsFolder[ItemName], QuestData)
                    end
                end
                task.wait(5)
            end
            Success = true
            task.wait(5)
        end
        if Success then
            StatusLabel.TextColor3 = Color3.fromRGB(155, 255, 175)
            StatusLabel.Text = "success!  discord.gg/popdupe"
        else
