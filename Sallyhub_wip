-- Remote helper
local function GetRemotes()
    local RE = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if not RE then return nil, nil, nil end
    return RE:FindFirstChild("GetItem"), RE:FindFirstChild("Drop"), RE:FindFirstChild("Equip")
end

-- Inventory count
local function GetItemCount(itemName)
    local count = 0
    -- Check backpack
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            if child.Name == itemName then count = count + 1 end
        end
    end
    -- Check character
    local char = LocalPlayer.Character
    if char then
        for _, child in ipairs(char:GetChildren()) do
            if child.Name == itemName then count = count + 1 end
        end
    end
    -- Check Inventory folder if exists (some games use a separate folder)
    local inv = LocalPlayer:FindFirstChild("Inventory")
    if inv then
        for _, child in ipairs(inv:GetChildren()) do
            if child.Name == itemName then count = count + 1 end
        end
    end
    return count
end

-- Dupe loop state
local isDupeRunning = false
local stopDupe = false

local function DupeLoop(itemName)
    if isDupeRunning then return end
    isDupeRunning = true
    stopDupe = false
    StopButton.Visible = true
    DupeButton.Visible = false
    StatusLabel.Text = "Starting dupe for: " .. itemName
    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)

    local GetItem, _, _ = GetRemotes()
    if not GetItem then
        StatusLabel.Text = "Error: GetItem remote not found"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        isDupeRunning = false
        StopButton.Visible = false
        DupeButton.Visible = true
        return
    end

    local ItemsFolder = ReplicatedStorage:FindFirstChild("Items")
    if not ItemsFolder then
        StatusLabel.Text = "Error: Items folder not found"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        isDupeRunning = false
        StopButton.Visible = false
        DupeButton.Visible = true
        return
    end

    local item = ItemsFolder:FindFirstChild(itemName)
    if not item then
        StatusLabel.Text = "Error: Item not found in game"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        isDupeRunning = false
        StopButton.Visible = false
        DupeButton.Visible = true
        return
    end

    local initialCount = GetItemCount(itemName)
    StatusLabel.Text = string.format("Initial count: %d. Duping...", initialCount)
    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)

    local attempts = 0
    local lastCount = initialCount
    local consecutiveFail = 0

    task.spawn(function()
        while not stopDupe and isDupeRunning do
            attempts = attempts + 1
            -- Fire dupe remote (using the quest method)
            pcall(function()
                GetItem:FireServer(item, {
                    questName = "Hole",
                    prizeItem = itemName,
                    questRequiredItems = {"Simple Dimple"}
                })
            end)

            task.wait(0.5) -- small delay to allow inventory update

            local currentCount = GetItemCount(itemName)
            if currentCount > lastCount then
                consecutiveFail = 0
                lastCount = currentCount
                StatusLabel.Text = string.format("Count: %d (attempt %d)", currentCount, attempts)
                StatusLabel.TextColor3 = Color3.fromRGB(155, 255, 175)
            else
                consecutiveFail = consecutiveFail + 1
                if consecutiveFail >= 5 then
                    StatusLabel.Text = "Stopped: No progress after 5 attempts"
                    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                    stopDupe = true
                    isDupeRunning = false
                    StopButton.Visible = false
                    DupeButton.Visible = true
                    return
                end
            end

            if attempts % 10 == 0 then
                StatusLabel.Text = string.format("Count: %d (%d attempts)", currentCount, attempts)
            end
        end

        if stopDupe then
            StatusLabel.Text = "Stopped by user"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 180, 60)
        else
            StatusLabel.Text = "Duping complete"
            StatusLabel.TextColor3 = Color3.fromRGB(155, 255, 175)
        end
        isDupeRunning = false
        StopButton.Visible = false
        DupeButton.Visible = true
    end)
end

