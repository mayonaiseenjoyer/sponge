local function StartDupeLoop(itemName)
    if isDuping then return end
    if not itemName or itemName == "" then
        DupeStatus.Text = "Please enter an item name"
        DupeStatus.TextColor3 = Color3.fromRGB(255, 180, 60)
        return
    end

    local GetItem, _, _ = GetRemotes()
    if not GetItem then
        DupeStatus.Text = "Error: GetItem remote not found"
        DupeStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    local ItemsFolder = ReplicatedStorage:FindFirstChild("Items")
    if not ItemsFolder then
        DupeStatus.Text = "Error: Items folder not found"
        DupeStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    local item = ItemsFolder:FindFirstChild(itemName)
    if not item then
        DupeStatus.Text = "Error: Item not found in game"
        DupeStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    local QuestSettings = ReplicatedStorage:FindFirstChild("QuestSettings")
    if not QuestSettings then
        DupeStatus.Text = "Error: QuestSettings not found"
        DupeStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    isDuping = true
    stopDuping = false
    ShowOverlay()

    local totalSent = 0

    task.spawn(function()
        local Quests = require(QuestSettings)
        local success = false
        for _, itemName in ipairs({itemName}) do
            local questData = {questName = "Hole", prizeItem = itemName, questRequiredItems = {"Simple Dimple"}}
            for questId, questInfo in pairs(Quests) do
                if stopDuping then break end
                local required = questInfo.questRequiredItems or {}
                for _, req in ipairs(required) do
                    if ItemsFolder:FindFirstChild(req) then
                        GetItem:FireServer(ItemsFolder[req], questData)
                        GetItem:FireServer(ItemsFolder[req], questData)
                        totalSent = totalSent + 2
                        if overlayLabel then overlayLabel.Text = string.format("Duping... Count: %d", totalSent) end
                        task.wait(0.05)
                    end
                end
                for i = 1, 350 do
                    if stopDuping then break end
                    if ItemsFolder:FindFirstChild(itemName) then
                        GetItem:FireServer(ItemsFolder[itemName], questData)
                        GetItem:FireServer(ItemsFolder[itemName], questData)
                        totalSent = totalSent + 2
                        if overlayLabel then overlayLabel.Text = string.format("Duping... Count: %d", totalSent) end
                        task.wait(0.05)
                    end
                end
                if stopDuping then break end
                local nextQuest = Quests[questId + 1]
                if nextQuest then
                    local nextRequired = nextQuest.questRequiredItems or {}
                    for _, req in ipairs(nextRequired) do
                        if ItemsFolder:FindFirstChild(req) then
                            GetItem:FireServer(ItemsFolder[req], questData)
                            GetItem:FireServer(ItemsFolder[req], questData)
                            totalSent = totalSent + 2
                            if overlayLabel then overlayLabel.Text = string.format("Duping... Count: %d", totalSent) end
                            task.wait(0.05)
                        end
                    end
                end
                for i = 1, 355 do
                    if stopDuping then break end
                    if ItemsFolder:FindFirstChild(itemName) then
                        GetItem:FireServer(ItemsFolder[itemName], questData)
                        GetItem:FireServer(ItemsFolder[itemName], questData)
                        totalSent = totalSent + 2
                        if overlayLabel then overlayLabel.Text = string.format("Duping... Count: %d", totalSent) end
                        task.wait(0.05)
                    end
                end
                task.wait(5)
            end
            success = true
            task.wait(5)
        end
        if stopDuping then
            DupeStatus.Text = "Stopped by user"
            DupeStatus.TextColor3 = Color3.fromRGB(255, 180, 60)
        else
            DupeStatus.Text = string.format("Duping complete! Sent %d items", totalSent)
            DupeStatus.TextColor3 = Color3.fromRGB(155, 255, 175)
        end
        isDuping = false
        HideOverlay()
    end)

    if overlayStop then
        overlayStop.MouseButton1Click:Connect(function()
            stopDuping = true
            isDuping = false
            HideOverlay()
        end)
    end
end

