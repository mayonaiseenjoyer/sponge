local DragData = {dragging = false, startPos = nil, offset = nil}

local function onDragStart(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
    if input.UserInputState == Enum.UserInputState.Begin then
        local ap = MainFrame.AbsolutePosition
        local as = MainFrame.AbsoluteSize
        local x, y = input.Position.X, input.Position.Y
        if x >= ap.X and x <= ap.X + as.X and y >= ap.Y and y <= ap.Y + 34 then
            DragData.dragging = true
            DragData.startPos = input.Position
            DragData.offset = MainFrame.Position
        end
    end
end

local function onDragEnd(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
    if input.UserInputState == Enum.UserInputState.End then
        DragData.dragging = false
    end
end

local function onDragMove(input)
    if not DragData.dragging then return end
    local delta = input.Position - DragData.startPos
    MainFrame.Position = UDim2.new(DragData.offset.X.Scale, DragData.offset.X.Offset + delta.X, DragData.offset.Y.Scale, DragData.offset.Y.Offset + delta.Y)
end

TitleBar.InputBegan:Connect(onDragStart)
TitleBar.InputEnded:Connect(onDragEnd)
TitleBar.InputChanged:Connect(onDragMove)

