    task.spawn(function()
        for i = 1, 15 do
            Drop:FireServer(itemName)
            Equip:FireServer(itemName)
            task.wait(0.25)
        end
        StatusLabel.Text = "Fast dropped + equipped " .. itemName .. " x15"
        StatusLabel.TextColor3 = Color3.fromRGB(155, 255, 175)
    end)
end)

